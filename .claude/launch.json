{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{let f=require('path').join(process.cwd(),q.url==='/'?'index.html':q.url);require('fs').readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end()}else{let t={'html':'text/html','css':'text/css','js':'text/javascript','svg':'image/svg+xml','png':'image/png','jpg':'image/jpeg'}[f.split('.').pop()]||'application/octet-stream';r.writeHead(200,{'Content-Type':t});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
